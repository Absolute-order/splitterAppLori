# Backend environment variables for local development.
#
# Docker users can usually run without copying this file because
# docker-compose.yml provides safe local defaults. For local npm dev,
# copy this file to backend/.env and adjust DATABASE_URL if needed.

PORT=8080
NODE_ENV=development

# Must be at least 16 characters.
JWT_SECRET=student_dev_jwt_secret_change_me

# If PostgreSQL is running through docker-compose on your computer:
DATABASE_URL="postgresql://admin:supersecret@localhost:5432/splitter?schema=public"

# Easy local development CORS mode.
ALLOW_ALL_CORS=1
JSON_BODY_LIMIT=4mb

# Optional: real receipt parsing. Without this, backend returns mock parsed items.
# GEMINI_API_KEY=

# Optional: separate invite secrets. If empty, JWT_SECRET is used as fallback.
# FRIEND_INVITE_SECRET=
# GROUP_INVITE_SECRET=

# Optional: avatar upload through Cloudflare R2.
# R2_ENDPOINT=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=
# CDN_BASE_URL=