# Backend API URL used by Expo.
#
# Browser/web on the same computer:
# EXPO_PUBLIC_API_URL=http://localhost:8080
#
# Expo Go on a real phone:
# 1. Find your computer local IP address.
# 2. Replace 192.168.1.23 with that IP.
# 3. Keep the :8080 port.
EXPO_PUBLIC_API_URL=http://192.168.1.23:8080

# Optional noisy logs for history API debugging.
EXPO_PUBLIC_DEBUG_HISTORY=0